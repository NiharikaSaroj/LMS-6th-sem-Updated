<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.StudentController">

    <top>
        <HBox spacing="15" alignment="CENTER" style="-fx-padding:15; -fx-background-color:#2c3e50;">
            <Button text="⬅ Dashboard"
                    onAction="#openDashboard"
                    style="-fx-background-color:#3498db; -fx-text-fill:white;" />
            <Label text="Student Management"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15" alignment="CENTER" style="-fx-padding:20;">

            <TextField fx:id="studentNameField"
                       promptText="Enter Student Name"
                       prefWidth="250"/>

            <TextField fx:id="courseField"
                       promptText="Enter Course"
                       prefWidth="250"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Add Student"
                        onAction="#addStudent"
                        style="-fx-background-color:#27ae60; -fx-text-fill:white;"/>

                <Button text="Delete Student"
                        onAction="#deleteStudent"
                        style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>
            </HBox>

            <TableView fx:id="studentTable" prefWidth="400" prefHeight="300">
                <columns>
                    <TableColumn fx:id="studentNameColumn"
                                 text="Student Name"
                                 prefWidth="380"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>